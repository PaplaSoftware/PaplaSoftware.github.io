---
// Page composition: assembles all sections inside the base layout.
// Content lives in src/i18n/ui.ts; each section reads it via its `lang` prop.
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "./Header.astro";
import Hero from "./Hero.astro";
import Services from "./Services.astro";
import LocalServices from "./LocalServices.astro";
import Printing from "./Printing.astro";
import Products from "./Products.astro";
import Contact from "./Contact.astro";
import Footer from "./Footer.astro";
import { type Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<BaseLayout lang={lang}>
  <Header lang={lang} />
  <main id="top">
    <Hero lang={lang} />
    <Services lang={lang} />
    <LocalServices lang={lang} />
    <Printing lang={lang} />
    <Products lang={lang} />
    <Contact lang={lang} />
  </main>
  <Footer lang={lang} />
</BaseLayout>
