---
import { useTranslations, type Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="services" class="scroll-mt-20 border-t border-white/5 py-20 sm:py-28 light:border-slate-200">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-widest text-emerald-400 light:text-emerald-600">
        {t.services.eyebrow}
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl light:text-slate-900">
        {t.services.title}
      </h2>
      <p class="mt-4 text-lg text-slate-400 light:text-slate-600">{t.services.lead}</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {t.services.items.map((item, idx) => (
        <article
          class="group rounded-2xl border border-white/10 bg-slate-900/50 p-7 transition-colors hover:border-emerald-400/40 hover:bg-slate-900 light:border-slate-200 light:bg-white light:hover:border-emerald-400 light:hover:bg-slate-50"
        >
          <div
            class="grid size-12 place-items-center rounded-xl bg-emerald-400/10 text-emerald-300 ring-1 ring-emerald-400/20 light:text-emerald-600"
          >
            {idx === 0 && (
              <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            )}
            {idx === 1 && (
              <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
            )}
            {idx === 2 && (
              <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 6v6l4 2"/></svg>
            )}
          </div>
          <h3 class="mt-5 text-lg font-semibold text-white light:text-slate-900">{item.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400 light:text-slate-600">{item.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>
