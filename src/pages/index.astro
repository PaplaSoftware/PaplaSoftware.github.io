---
import "../styles/global.css";

// --- Dane firmy (edytuj w jednym miejscu) ---
const company = {
  name: "Przemysław Papla - Software",
  short: "Papla Software",
  street: "Wrzosowa 6",
  city: "43-370 Szczyrk",
  nip: "9372761119",
  regon: "528464558",
  // TODO: podmień na docelowe dane kontaktowe
  email: "kontakt@paplasoftware.pl",
  phone: "+48 000 000 000",
  phoneHref: "+48000000000",
};

// Formularz na stronie statycznej nie ma backendu.
// Wklej tu swój endpoint z https://formspree.io (darmowy) — inaczej użyty
// zostanie fallback `mailto:`.
const FORMSPREE_ENDPOINT = ""; // np. "https://formspree.io/f/xxxxxxx"
const formAction = FORMSPREE_ENDPOINT || `mailto:${company.email}`;
const formMethod = FORMSPREE_ENDPOINT ? "POST" : "GET";

const year = new Date().getFullYear();

const nav = [
  { href: "#uslugi", label: "Usługi B2B" },
  { href: "#lokalne", label: "Usługi lokalne" },
  { href: "#produkty", label: "Produkty" },
  { href: "#kontakt", label: "Kontakt" },
];
---

<!doctype html>
<html lang="pl" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta
      name="description"
      content="Przemysław Papla - Software: dedykowane oprogramowanie i audyty kodu (B2B), usługi lokalne w Szczyrku i okolicach oraz wypożyczalnia sprzętu."
    />
    <meta name="theme-color" content="#020617" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{company.name} — technologia i niezawodność dla biznesu</title>
  </head>

  <body class="bg-slate-950 text-slate-300 antialiased selection:bg-emerald-400/20 selection:text-emerald-100">
    <!-- ===================== HEADER ===================== -->
    <header
      class="fixed inset-x-0 top-0 z-50 border-b border-white/5 bg-slate-950/70 backdrop-blur-lg"
    >
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <a href="#top" class="flex items-center gap-2.5 font-semibold text-white">
          <span
            class="grid size-9 place-items-center rounded-lg bg-gradient-to-br from-emerald-400 to-teal-500 text-slate-950 shadow-lg shadow-emerald-500/20"
          >
            <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m16 18 6-6-6-6"/><path d="m8 6-6 6 6 6"/></svg>
          </span>
          <span class="tracking-tight">{company.short}</span>
        </a>

        <nav class="hidden items-center gap-8 md:flex">
          {nav.map((item) => (
            <a
              href={item.href}
              class="text-sm font-medium text-slate-400 transition-colors hover:text-white"
            >
              {item.label}
            </a>
          ))}
        </nav>

        <a
          href="#kontakt"
          class="rounded-lg bg-white/5 px-4 py-2 text-sm font-semibold text-white ring-1 ring-white/10 transition-all hover:bg-emerald-400 hover:text-slate-950 hover:ring-emerald-400"
        >
          Napisz do mnie
        </a>
      </div>
    </header>

    <main id="top">
      <!-- ===================== HERO ===================== -->
      <section class="relative overflow-hidden pt-32 pb-24 sm:pt-40 sm:pb-32">
        <!-- tło: siatka + poświata -->
        <div
          class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(60%_50%_at_50%_0%,rgba(16,185,129,0.14),transparent_70%)]"
        >
        </div>
        <div
          class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(to_right,rgba(148,163,184,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(148,163,184,0.06)_1px,transparent_1px)] bg-[size:56px_56px] [mask-image:radial-gradient(70%_60%_at_50%_0%,black,transparent)]"
        >
        </div>

        <div class="mx-auto max-w-6xl px-4 text-center sm:px-6 lg:px-8">
          <span
            class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs font-medium text-slate-300"
          >
            <span class="size-2 rounded-full bg-emerald-400 shadow-[0_0_10px] shadow-emerald-400"></span>
            Software · Usługi lokalne · Produkty własne
          </span>

          <h1
            class="mx-auto mt-8 max-w-4xl text-balance text-4xl font-extrabold leading-[1.1] tracking-tight text-white sm:text-5xl lg:text-6xl"
          >
            Technologia i niezawodność —
            <span
              class="bg-gradient-to-r from-emerald-300 via-teal-300 to-sky-400 bg-clip-text text-transparent"
            >
              usługi dla biznesu i klientów indywidualnych
            </span>
          </h1>

          <p class="mx-auto mt-6 max-w-2xl text-pretty text-lg leading-relaxed text-slate-400">
            Dedykowane oprogramowanie i audyty kodu dla firm, praktyczne usługi
            lokalne w Szczyrku i okolicach oraz własne produkty elektroniczne.
            Jedna działalność — wiele źródeł wartości.
          </p>

          <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
            <a
              href="#uslugi"
              class="inline-flex items-center gap-2 rounded-xl bg-emerald-400 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-500/20 transition-transform hover:-translate-y-0.5 hover:bg-emerald-300"
            >
              Zobacz zakres usług
              <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a
              href="#kontakt"
              class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/10"
            >
              Kontakt
            </a>
          </div>
        </div>
      </section>

      <!-- ===================== USŁUGI B2B / SOFTWARE ===================== -->
      <section id="uslugi" class="scroll-mt-20 border-t border-white/5 py-20 sm:py-28">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
          <div class="max-w-2xl">
            <p class="text-sm font-semibold uppercase tracking-widest text-emerald-400">
              Software / B2B
            </p>
            <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
              Oprogramowanie, które realnie działa
            </h2>
            <p class="mt-4 text-lg text-slate-400">
              Współpraca w modelu B2B — od pojedynczego audytu po długoterminowe
              wsparcie inżynierskie.
            </p>
          </div>

          <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            <!-- karta -->
            <article
              class="group rounded-2xl border border-white/10 bg-slate-900/50 p-7 transition-colors hover:border-emerald-400/40 hover:bg-slate-900"
            >
              <div
                class="grid size-12 place-items-center rounded-xl bg-emerald-400/10 text-emerald-300 ring-1 ring-emerald-400/20"
              >
                <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              </div>
              <h3 class="mt-5 text-lg font-semibold text-white">
                Dedykowane oprogramowanie
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">
                Projektowanie i budowa aplikacji webowych oraz narzędzi szytych
                pod konkretny proces biznesowy — od API po interfejs użytkownika.
              </p>
            </article>

            <article
              class="group rounded-2xl border border-white/10 bg-slate-900/50 p-7 transition-colors hover:border-emerald-400/40 hover:bg-slate-900"
            >
              <div
                class="grid size-12 place-items-center rounded-xl bg-emerald-400/10 text-emerald-300 ring-1 ring-emerald-400/20"
              >
                <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M21 12c-1 0-3-1-3-3s2-3 3-3-2-3-3-3-3 2-3 3 1 3 3 3z"/><path d="M3 12c1 0 3 1 3 3s-2 3-3 3 2 3 3 3 3-2 3-3-1-3-3-3z"/></svg>
              </div>
              <h3 class="mt-5 text-lg font-semibold text-white">Audyty kodu</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">
                Przegląd jakości, bezpieczeństwa i architektury istniejącego
                kodu. Konkretne rekomendacje i priorytety zamiast ogólników.
              </p>
            </article>

            <article
              class="group rounded-2xl border border-white/10 bg-slate-900/50 p-7 transition-colors hover:border-emerald-400/40 hover:bg-slate-900"
            >
              <div
                class="grid size-12 place-items-center rounded-xl bg-emerald-400/10 text-emerald-300 ring-1 ring-emerald-400/20"
              >
                <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 6v6l4 2"/></svg>
              </div>
              <h3 class="mt-5 text-lg font-semibold text-white">
                Usługi programistyczne B2B
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">
                Wsparcie zespołów inżynierskich, code review, rozwój i utrzymanie
                systemów. Rozliczenie w modelu B2B, faktura VAT.
              </p>
            </article>
          </div>
        </div>
      </section>

      <!-- ===================== USŁUGI LOKALNE / WYPOŻYCZALNIA ===================== -->
      <section id="lokalne" class="scroll-mt-20 border-t border-white/5 bg-slate-900/30 py-20 sm:py-28">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
          <div class="max-w-2xl">
            <p class="text-sm font-semibold uppercase tracking-widest text-sky-400">
              Szczyrk i okolice
            </p>
            <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
              Usługi lokalne i wypożyczalnia sprzętu
            </h2>
            <p class="mt-4 text-lg text-slate-400">
              Praktyczna pomoc na miejscu oraz sprzęt do wynajęcia, gdy potrzebny
              jest tylko na chwilę.
            </p>
          </div>

          <div class="mt-14 grid gap-6 md:grid-cols-2">
            <article
              class="flex gap-5 rounded-2xl border border-white/10 bg-slate-900/60 p-7 transition-colors hover:border-sky-400/40"
            >
              <div
                class="grid size-12 shrink-0 place-items-center rounded-xl bg-sky-400/10 text-sky-300 ring-1 ring-sky-400/20"
              >
                <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-white">
                  Awaryjne odpalanie aut
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-400">
                  Rozładowany akumulator? Pomoc w odpaleniu samochodu na terenie
                  Szczyrku i okolic. Szybki dojazd, bez zbędnych formalności.
                </p>
                <a
                  href={`tel:${company.phoneHref}`}
                  class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-sky-300 hover:text-sky-200"
                >
                  Zadzwoń po pomoc
                  <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              </div>
            </article>

            <article
              class="flex gap-5 rounded-2xl border border-white/10 bg-slate-900/60 p-7 transition-colors hover:border-sky-400/40"
            >
              <div
                class="grid size-12 shrink-0 place-items-center rounded-xl bg-sky-400/10 text-sky-300 ring-1 ring-sky-400/20"
              >
                <svg class="size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h20"/><path d="M4 12V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4"/><path d="M6 20v-4"/><path d="M18 20v-4"/><rect x="4" y="12" width="16" height="4" rx="1"/></svg>
              </div>
              <div>
                <h3 class="text-lg font-semibold text-white">
                  Wypożyczalnia sprzętu
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-slate-400">
                  Sprzęt do wynajęcia, m.in. <span class="text-slate-200">agregat malarski</span> —
                  idealny do jednorazowych remontów bez inwestowania we własne
                  urządzenie. Elastyczne okresy najmu.
                </p>
                <a
                  href="#kontakt"
                  class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-sky-300 hover:text-sky-200"
                >
                  Zapytaj o dostępność
                  <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              </div>
            </article>
          </div>
        </div>
      </section>

      <!-- ===================== PRODUKTY ===================== -->
      <section id="produkty" class="scroll-mt-20 border-t border-white/5 py-20 sm:py-28">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
          <div class="max-w-2xl">
            <p class="text-sm font-semibold uppercase tracking-widest text-amber-400">
              Produkty własne
            </p>
            <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
              Elektronika projektowana od podstaw
            </h2>
          </div>

          <div class="mt-14 grid gap-8 lg:grid-cols-2 lg:items-center">
            <!-- wizual produktu -->
            <div
              class="relative aspect-[4/3] overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-amber-500/10 via-slate-900 to-slate-950"
            >
              <div
                class="pointer-events-none absolute inset-0 bg-[radial-gradient(50%_50%_at_50%_45%,rgba(251,191,36,0.25),transparent_70%)]"
              >
              </div>
              <div class="absolute inset-0 grid place-items-center">
                <svg class="size-28 text-amber-300/90 drop-shadow-[0_0_40px_rgba(251,191,36,0.4)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5C17.7 10.2 18 9 18 8a6 6 0 0 0-12 0c0 1 .3 2.2 1.5 3.5.8.8 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
              </div>
              <span
                class="absolute left-5 top-5 inline-flex items-center gap-2 rounded-full border border-amber-400/30 bg-amber-400/10 px-3 py-1 text-xs font-semibold text-amber-200"
              >
                <span class="size-1.5 rounded-full bg-amber-300"></span>
                Coming Soon · Wkrótce w sprzedaży
              </span>
            </div>

            <!-- opis produktu -->
            <div>
              <h3 class="text-2xl font-bold text-white">
                Inteligentna lampka drewniana
              </h3>
              <p class="mt-4 text-slate-400">
                Autorski produkt łączący naturalne, ręcznie wykończone drewno z
                nowoczesną elektroniką. Sercem urządzenia jest
                <span class="text-slate-200">własne PCB</span> sterujące
                <span class="text-slate-200">adresowalnym oświetleniem LED RGB</span>.
              </p>
              <ul class="mt-6 space-y-3 text-sm text-slate-300">
                <li class="flex items-start gap-3">
                  <svg class="mt-0.5 size-5 shrink-0 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  Autorski projekt PCB i firmware
                </li>
                <li class="flex items-start gap-3">
                  <svg class="mt-0.5 size-5 shrink-0 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  Pełna paleta kolorów LED RGB i płynne sceny świetlne
                </li>
                <li class="flex items-start gap-3">
                  <svg class="mt-0.5 size-5 shrink-0 text-amber-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  Naturalne drewno, ręczne wykończenie każdego egzemplarza
                </li>
              </ul>
              <div class="mt-8">
                <a
                  href="#kontakt"
                  class="inline-flex items-center gap-2 rounded-xl border border-amber-400/30 bg-amber-400/10 px-5 py-3 text-sm font-semibold text-amber-200 transition-colors hover:bg-amber-400/20"
                >
                  Zapisz się na informację o premierze
                  <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ===================== KONTAKT ===================== -->
      <section id="kontakt" class="scroll-mt-20 border-t border-white/5 bg-slate-900/30 py-20 sm:py-28">
        <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
          <div class="grid gap-12 lg:grid-cols-2">
            <!-- lewa kolumna: dane -->
            <div>
              <p class="text-sm font-semibold uppercase tracking-widest text-emerald-400">
                Kontakt
              </p>
              <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
                Porozmawiajmy o współpracy
              </h2>
              <p class="mt-4 text-lg text-slate-400">
                Napisz w sprawie projektu software'owego, usługi lokalnej lub
                produktu. Odpowiadam zwykle w ciągu jednego dnia roboczego.
              </p>

              <div class="mt-8 space-y-4">
                <a
                  href={`mailto:${company.email}`}
                  class="flex items-center gap-4 rounded-xl border border-white/10 bg-slate-900/60 p-4 transition-colors hover:border-emerald-400/40"
                >
                  <span class="grid size-11 place-items-center rounded-lg bg-emerald-400/10 text-emerald-300 ring-1 ring-emerald-400/20">
                    <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  </span>
                  <span>
                    <span class="block text-xs text-slate-500">E-mail</span>
                    <span class="font-medium text-white">{company.email}</span>
                  </span>
                </a>

                <a
                  href={`tel:${company.phoneHref}`}
                  class="flex items-center gap-4 rounded-xl border border-white/10 bg-slate-900/60 p-4 transition-colors hover:border-emerald-400/40"
                >
                  <span class="grid size-11 place-items-center rounded-lg bg-emerald-400/10 text-emerald-300 ring-1 ring-emerald-400/20">
                    <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  </span>
                  <span>
                    <span class="block text-xs text-slate-500">Telefon</span>
                    <span class="font-medium text-white">{company.phone}</span>
                  </span>
                </a>
              </div>

              <!-- dane rejestrowe -->
              <div class="mt-8 rounded-2xl border border-white/10 bg-slate-950/60 p-6">
                <h3 class="text-sm font-semibold uppercase tracking-widest text-slate-500">
                  Dane rejestrowe
                </h3>
                <dl class="mt-4 space-y-2.5 text-sm">
                  <div class="flex justify-between gap-4">
                    <dt class="text-slate-500">Firma</dt>
                    <dd class="text-right font-medium text-white">{company.name}</dd>
                  </div>
                  <div class="flex justify-between gap-4">
                    <dt class="text-slate-500">Adres</dt>
                    <dd class="text-right text-slate-200">
                      {company.street}, {company.city}
                    </dd>
                  </div>
                  <div class="flex justify-between gap-4">
                    <dt class="text-slate-500">NIP</dt>
                    <dd class="text-right font-mono text-slate-200">{company.nip}</dd>
                  </div>
                  <div class="flex justify-between gap-4">
                    <dt class="text-slate-500">REGON</dt>
                    <dd class="text-right font-mono text-slate-200">{company.regon}</dd>
                  </div>
                </dl>
              </div>
            </div>

            <!-- prawa kolumna: formularz -->
            <div class="rounded-2xl border border-white/10 bg-slate-900/60 p-6 sm:p-8">
              <form action={formAction} method={formMethod} class="space-y-5">
                <div>
                  <label for="name" class="mb-1.5 block text-sm font-medium text-slate-300">
                    Imię i nazwisko
                  </label>
                  <input
                    id="name"
                    name="name"
                    type="text"
                    required
                    autocomplete="name"
                    placeholder="Jan Kowalski"
                    class="w-full rounded-xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-white placeholder-slate-500 outline-none transition focus:border-emerald-400/60 focus:ring-2 focus:ring-emerald-400/20"
                  />
                </div>

                <div>
                  <label for="email" class="mb-1.5 block text-sm font-medium text-slate-300">
                    E-mail
                  </label>
                  <input
                    id="email"
                    name="email"
                    type="email"
                    required
                    autocomplete="email"
                    placeholder="jan@firma.pl"
                    class="w-full rounded-xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-white placeholder-slate-500 outline-none transition focus:border-emerald-400/60 focus:ring-2 focus:ring-emerald-400/20"
                  />
                </div>

                <div>
                  <label for="topic" class="mb-1.5 block text-sm font-medium text-slate-300">
                    Temat
                  </label>
                  <select
                    id="topic"
                    name="topic"
                    class="w-full rounded-xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-white outline-none transition focus:border-emerald-400/60 focus:ring-2 focus:ring-emerald-400/20"
                  >
                    <option>Usługi software / B2B</option>
                    <option>Audyt kodu</option>
                    <option>Usługa lokalna (Szczyrk i okolice)</option>
                    <option>Wypożyczalnia sprzętu</option>
                    <option>Inteligentna lampka drewniana</option>
                    <option>Inne</option>
                  </select>
                </div>

                <div>
                  <label for="message" class="mb-1.5 block text-sm font-medium text-slate-300">
                    Wiadomość
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    rows="4"
                    required
                    placeholder="W czym mogę pomóc?"
                    class="w-full resize-y rounded-xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-white placeholder-slate-500 outline-none transition focus:border-emerald-400/60 focus:ring-2 focus:ring-emerald-400/20"
                  ></textarea>
                </div>

                <button
                  type="submit"
                  class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-emerald-400 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-500/20 transition-colors hover:bg-emerald-300"
                >
                  Wyślij wiadomość
                  <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/><path d="m21.854 2.147-10.94 10.939"/></svg>
                </button>

                <p class="text-center text-xs text-slate-500">
                  Wysyłając formularz akceptujesz kontakt zwrotny w sprawie zapytania.
                </p>
              </form>
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- ===================== FOOTER ===================== -->
    <footer class="border-t border-white/5 bg-slate-950">
      <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">
          <div class="max-w-sm">
            <div class="flex items-center gap-2.5 font-semibold text-white">
              <span
                class="grid size-9 place-items-center rounded-lg bg-gradient-to-br from-emerald-400 to-teal-500 text-slate-950"
              >
                <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m16 18 6-6-6-6"/><path d="m8 6-6 6 6 6"/></svg>
              </span>
              {company.short}
            </div>
            <p class="mt-4 text-sm leading-relaxed text-slate-500">
              Technologia i niezawodność — usługi dla biznesu i klientów
              indywidualnych. Software, usługi lokalne i produkty własne.
            </p>
          </div>

          <div class="text-sm leading-relaxed text-slate-400">
            <p class="font-medium text-slate-200">{company.name}</p>
            <p class="mt-2">{company.street}</p>
            <p>{company.city}</p>
            <p class="mt-2">NIP: <span class="font-mono">{company.nip}</span></p>
            <p>REGON: <span class="font-mono">{company.regon}</span></p>
          </div>
        </div>

        <div
          class="mt-10 flex flex-col items-center justify-between gap-3 border-t border-white/5 pt-6 text-xs text-slate-600 sm:flex-row"
        >
          <p>© {year} {company.name}. Wszelkie prawa zastrzeżone.</p>
          <p>Zbudowano w Astro + Tailwind CSS.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
